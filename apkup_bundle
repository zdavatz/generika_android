#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
UPLOADER_DIR="$SCRIPT_DIR/../android-bundle-uploader"
CREDENTIALS="$SCRIPT_DIR/generika.json"
PACKAGE="org.oddb.generika"
AAB="$SCRIPT_DIR/app/build/outputs/bundle/release/app-release.aab"
TRACK="${1:-production}"

cd "$SCRIPT_DIR"

echo "==> Cleaning..."
make clean

echo "==> Building release bundle..."
./gradlew bundleRelease

if [ ! -f "$AAB" ]; then
    echo "ERROR: Bundle not found at $AAB"
    exit 1
fi

echo "==> Uploading to Google Play ($TRACK track)..."
python3 "$UPLOADER_DIR/main.py" "$CREDENTIALS" "$PACKAGE" "$AAB" "$TRACK"

echo "==> Done!"
